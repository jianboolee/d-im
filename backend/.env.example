# ============================================================
# d-im 环境变量配置模板
# 复制为 .env 后修改，环境变量优先级高于 configs/config.yaml
# ============================================================

# 应用
APP_ENV=development
APP_FRONTEND_URL=http://localhost:5173

# Auth
IM_SUPER_PASSWORD=

# MongoDB
MONGODB_URI=mongodb://localhost:27018
MONGODB_DATABASE=im_db
MONGODB_POOL_SIZE=100
MONGODB_TIMEOUT=10

# Redis
REDIS_ADDR=localhost:6380
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=50

# NATS
NATS_URL=nats://localhost:4223
NATS_USER=
NATS_PASSWORD=
NATS_PUBLISH_TIMEOUT=2s
NATS_SUBJECTS_MESSAGE_SEND=im.message.send
NATS_SUBJECTS_MESSAGE_PUSH=im.message.push
NATS_SUBJECTS_MESSAGE_EVENT=im.message.event
NATS_SUBJECTS_USER_CREATED=dsaas.user.created
NATS_SUBJECTS_USER_UPDATED=dsaas.user.profile_updated
NATS_SUBJECTS_USER_STATUS=dsaas.user.status_changed
NATS_SUBJECTS_USER_DELETED=dsaas.user.deleted

# 雪花ID
SNOWFLAKE_WORKER_ID=1
SNOWFLAKE_DATACENTER_ID=1

# JWT
JWT_SECRET=change-me
JWT_API_KEY=change-me
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=168h
JWT_TICKET_EXPIRE=5m

# 日志
LOG_LEVEL=debug
LOG_FORMAT=console
LOG_OUTPUT=stdout

# 服务端口
SERVER_GATEWAY_HTTP_PORT=8080
SERVER_GATEWAY_GRPC_PORT=9080
SERVER_CONNECTOR_WS_PORT=8081
SERVER_CONNECTOR_TCP_PORT=8082
