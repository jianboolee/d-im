# ============================================================
# d-im 环境变量配置模板
# 复制为 .env 后修改，环境变量优先级高于 configs/config.yaml
# ============================================================

# 应用
APP_ENV=development
APP_FRONTEND_URL=http://localhost:5173

# Auth
IM_SUPER_PASSWORD=

# MongoDB
MONGODB_URI=mongodb://localhost:27018
MONGODB_DATABASE=im_db
MONGODB_POOL_SIZE=100
MONGODB_TIMEOUT=10

# Redis
REDIS_ADDR=localhost:6380
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=50

# NATS
NATS_URL=nats://localhost:4223
NATS_USER=
NATS_PASSWORD=
NATS_PUBLISH_TIMEOUT=2s
NATS_SUBJECTS_MESSAGE_SEND=im.message.send
NATS_SUBJECTS_MESSAGE_PUSH=im.message.push
NATS_SUBJECTS_MESSAGE_EVENT=im.message.event
NATS_SUBJECTS_USER_CREATED=dimuser.created
NATS_SUBJECTS_USER_UPDATED=dimuser.profile_updated
NATS_SUBJECTS_USER_STATUS=dimuser.status_changed
NATS_SUBJECTS_USER_DELETED=dimuser.deleted

# 雪花ID
SNOWFLAKE_WORKER_ID=1
SNOWFLAKE_DATACENTER_ID=1

# JWT
JWT_SECRET=change-me
JWT_API_KEY=change-me
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=168h
JWT_TICKET_EXPIRE=5m

# 日志
LOG_LEVEL=debug
LOG_FORMAT=console
LOG_OUTPUT=stdout

# 服务端口
SERVER_GATEWAY_HTTP_PORT=8080
SERVER_GATEWAY_GRPC_PORT=9080
SERVER_CONNECTOR_WS_PORT=8081
SERVER_CONNECTOR_TCP_PORT=8082

# Storage
# STORAGE_PROVIDER 用于选择上传文件写入位置。
# 可选值：local / aliyun_oss / qiniu
# 默认使用 local；切换到阿里云 OSS 时设置 STORAGE_PROVIDER=aliyun_oss，并填写下方 STORAGE_ALIYUN_OSS_*。
# 切换到七牛云时设置 STORAGE_PROVIDER=qiniu，并填写下方 STORAGE_QINIU_*。
STORAGE_PROVIDER=local
STORAGE_PUBLIC_BASE_URL=http://localhost:8080
STORAGE_MAX_IMAGE_SIZE=20971520
STORAGE_LOCAL_ROOT_DIR=./data/media
STORAGE_LOCAL_URL_PREFIX=/media

# 阿里云 OSS
STORAGE_ALIYUN_OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
STORAGE_ALIYUN_OSS_ACCESS_KEY_ID=
STORAGE_ALIYUN_OSS_ACCESS_KEY_SECRET=
STORAGE_ALIYUN_OSS_BUCKET=
STORAGE_ALIYUN_OSS_DIRECTORY=/media
STORAGE_ALIYUN_OSS_PUBLIC_BASE_URL=https://cdn.example.com

# 七牛云
STORAGE_QINIU_ACCESS_KEY=
STORAGE_QINIU_SECRET_KEY=
STORAGE_QINIU_BUCKET=
STORAGE_QINIU_REGION=
STORAGE_QINIU_PUBLIC_BASE_URL=https://cdn.example.com
